* {
    font-size: 11pt;
}

QMainWindow {
    background-color: @BG_PRIMARY@;
}

QMenuBar {
    background-color: @BG_SECONDARY@;
    color: @TEXT_PRIMARY@;
    border-bottom: 1px solid @BORDER@;
}

    QMenuBar::item:selected {
        background-color: @BG_TERTIARY@;
        color: @TEXT_PRIMARY@;
    }

    QMenuBar::item:pressed {
        background-color: @BG_TERTIARY@;
    }

QMenu {
    background-color: @BG_PRIMARY@;
    color: @TEXT_PRIMARY@;
    border: 1px solid @BORDER@;
}

    QMenu::item:selected {
        background-color: @BG_TERTIARY@;
        color: @TEXT_PRIMARY@;
    }

    QMenu::separator {
        height: 1px;
        background-color: @BORDER@;
        margin: 5px 0;
    }

QToolBar {
    background-color: @BG_SECONDARY@;
    border: none;
    spacing: 3px;
    padding: 2px;
}

QToolButton {
    background-color: transparent;
    border: none;
    border-radius: 3px;
    padding: 4px;
    color: @TEXT_PRIMARY@;
}

    QToolButton:hover {
        background-color: @BG_TERTIARY@;
    }

    QToolButton:pressed {
        background-color: @BG_TERTIARY@;
    }

QTabBar {
    margin: 0px;
    padding: 0px;
    border: none;
    background-color: none;
}

    QTabBar::tab {
        background-color: @BG_PRIMARY@;
        color: @TEXT_PRIMARY@;
        padding: 0.1em 0.2em;
        margin-right: 2px;
        border-top-left-radius: 4px;
        border-top-right-radius: 4px;
        border: 1px solid @BORDER@;
        border-bottom: none;
    }

    QTabBar::tab:selected {
        background-color: @BG_PRIMARY@;
        border-bottom: 2px solid @ACCENT@;
    }

    QTabBar::tab:hover {
        background-color: @BG_TERTIARY@;
    }

QDockWidget {
    background-color: @BG_PRIMARY@;
    color: @TEXT_PRIMARY@;
    border: none;
}

    QDockWidget::focus {
        border: 1px solid @SELECTION_BG@;
    }

    QDockWidget::title {
        background-color: @BG_SECONDARY@;
        padding-left: 5px;
        border: 1px solid @BORDER@;
        text-align: left;
    }

    QDockWidget::close-button, QDockWidget::float-button {
        background-color: @SCROLLBAR@;
        width: 1.2em;
        height: 1.2em;
        border-radius: 0.6em;
    }

        QDockWidget::close-button:hover, QDockWidget::float-button:hover {
            background-color: @TEXT_PRIMARY@;
        }

/* ===== LispEditor ===== */
LispEditor {
    background-color: @EDITOR_BG@;
    color: @EDITOR_TEXT@;
    font-family: 'Consolas', 'Monaco', 'Fira Code', monospace;
    font-size: 12pt;
    selection-background-color: @SELECTION_BG@;
    selection-color: @TEXT_PRIMARY@;
    border: 1px solid @BORDER@;
}

    /* Стили для области содержимого */
    LispEditor QWidget {
        margin: 0px;
        padding: 0px;
    }

/* ===== LineNumberArea ===== */
#LineNumberArea {
    background-color: @LINENUMBER_BG@;
    color: @LINENUMBER_TEXT@;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 11pt;
    border-right: 1px solid @BORDER@;
}

    #LineNumberArea[current-line="true"] {
        color: @TEXT_PRIMARY@;
        font-weight: bold;
    }

/* ===== ProjectTree ===== */
ProjectTree {
    color: @EDITOR_TEXT@;
    background-color: @BG_PRIMARY@;
    border: 1px solid @BORDER@;
    outline: none;
}

ProjectTree::item:selected {
    background-color: @SELECTION_BG@;
    border: none;
}

/* ===== Console ===== */
Console {
    background-color: @EDITOR_BG@;
    color: @EDITOR_TEXT@;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 11pt;
    border: none;
}

/* ===== QStatusBar ===== */
QStatusBar {
    background-color: @BG_PRIMARY@;
    color: @TEXT_PRIMARY@;
    font-weight: bold;
    border-top: 2px solid @BORDER@;
}

    QStatusBar QLabel {
        color: @TEXT_PRIMARY@;
        padding: 0 10px;
        border-right: 1px solid @BORDER@;
    }

        QStatusBar QLabel:last-child {
            border-right: none;
        }

/* ===== EditorTabWidget ===== */

EditorTabWidget::pane {
    border: none;
    background-color: @BG_PRIMARY@;
}

EditorTabWidget QTabBar::tab {
    background-color: @BG_SECONDARY@;
    color: @TEXT_PRIMARY@;
    padding: 5px 15px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border: 1px solid @BORDER@;
    border-bottom: none;
}

EditorTabWidget QTabBar::tab:selected {
    background-color: @BG_PRIMARY@;
    border-bottom: 2px solid @ACCENT@;
}

EditorTabWidget QTabBar::tab:hover {
    background-color: @BG_TERTIARY@;
}

EditorTabWidget QTabBar::tab:!selected {
    margin-top: 2px;
}

/* Индикатор изменённого файла (звёздочка) */
EditorTabWidget QTabBar::tab:modified {
    font-weight: bold;
}

EditorTabWidget QTabBar::tab:modified::after {
    content: " *";
    color: @ACCENT@;
}

/* ===== QScrollBar ===== */

QScrollBar:vertical {
    background-color: @BG_SECONDARY@;
    border: 1px solid @BORDER@;
    width: 0.6em;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background-color: @SCROLLBAR@;
    border-radius: 0.3em;
    min-height: 30px;
    margin: 0px;
}

QScrollBar::handle:vertical:hover {
    background-color: @SCROLLBAR_HOVER@;
}

QScrollBar::handle:vertical:pressed {
    background-color: @SCROLLBAR_HOVER@;
}

QScrollBar::sub-line:vertical, QScrollBar::add-line:vertical {
    height: 0px;
    border: none;
    background: none;
}

QScrollBar::sub-page:vertical, QScrollBar::add-page:vertical {
    background: transparent;
}

/* Горизонтальный скроллбар */
QScrollBar:horizontal {
    background-color: @BG_SECONDARY@;
    height: 0.6em;
    margin: 0px;
    border: none;
}

QScrollBar::handle:horizontal {
    background-color: @SCROLLBAR@;
    border-radius: 0.3em;
    min-width: 30px;
    margin: 0px;
}

QScrollBar::handle:horizontal:hover {
    background-color: @SCROLLBAR_HOVER@;
}

QScrollBar::handle:horizontal:pressed {
    background-color: @SCROLLBAR_HOVER@;
}

QScrollBar::sub-line:horizontal, QScrollBar::add-line:horizontal {
    width: 0px;
    border: none;
    background: none;
}

QScrollBar::sub-page:horizontal, QScrollBar::add-page:horizontal {
    background: transparent;
}

/* Отступ для горизонтального скроллбара с учётом LineNumberArea */
QAbstractScrollArea::corner {
    background-color: @LINENUMBER_BG@;
    border: none;
}